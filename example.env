# Azure endpoint values
# Canonical env vars used by agent_framework.azure.AzureOpenAIResponsesClient
AZURE_OPENAI_ENDPOINT=<REDACTED_URL>
AZURE_OPENAI_RESPONSES_DEPLOYMENT_NAME="gpt-4.1"

# Optional Entra ID auth settings
AZURE_CLI_PROCESS_TIMEOUT="60"

# Project endpoint (also used by some azure.ai.projects samples)
AZURE_AI_PROJECT_ENDPOINT=<REDACTED_URL>

# Compatibility aliases for other samples in this repo
PROJECT_ENDPOINT=<REDACTED_URL>
MODEL_DEPLOYMENT_NAME="gpt-4.1"
AGENT_NAME="MyAgent2"
